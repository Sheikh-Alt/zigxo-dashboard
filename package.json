    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.4.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^3.3.15",
    "openai": "^4.67.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "playwright": "^1.48.0",
    "tar-stream": "^3.1.7",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
